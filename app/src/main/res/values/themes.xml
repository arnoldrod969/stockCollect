<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StockCollect" parent="Theme.Material3.DayNight">
        <!-- Couleur principale : bleu JD Cosmetics -->
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/blue_container</item>
        <item name="colorOnPrimaryContainer">@color/blue_on_container</item>

        <!-- Couleur secondaire -->
        <item name="colorSecondary">@color/green_secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Toolbar -->
        <item name="actionBarStyle">@style/AppBarStyle</item>
        <item name="toolbarStyle">@style/ToolbarStyle</item>
    </style>

    <style name="AppBarStyle" parent="Widget.Material3.ActionBar.Solid">
        <item name="background">@color/blue_primary</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <style name="ToolbarStyle" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/blue_primary</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
    </style>
</resources>
