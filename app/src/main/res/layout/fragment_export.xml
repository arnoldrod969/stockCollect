<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/surface_variant">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Session à exporter"
        android:textSize="13sp" android:textColor="@color/on_surface_variant"
        android:layout_margin="16dp" android:id="@+id/tv_titre"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <TextView android:id="@+id/tv_aucune_session" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Aucune session clôturée à exporter."
        android:textColor="@color/on_surface_variant" android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_titre" app:layout_constraintBottom_toTopOf="@id/progress_export"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <com.google.android.material.card.MaterialCardView android:id="@+id/group_session"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp" android:visibility="gone"
        app:cardElevation="2dp" app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_titre"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">
            <TextView android:id="@+id/tv_type_operation" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tv_date_heure" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="12sp"
                android:textColor="@color/on_surface_variant" android:layout_marginTop="4dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="8dp">
                <TextView android:id="@+id/tv_statut" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="13sp"
                    android:textColor="@color/blue_primary" android:textStyle="bold"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <TextView android:id="@+id/tv_nb_lignes" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="13sp"
                    android:textColor="@color/on_surface_variant"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <ProgressBar android:id="@+id/progress_export" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:visibility="gone" android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/btn_exporter"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <com.google.android.material.button.MaterialButton android:id="@+id/btn_exporter"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="⬇ Générer et télécharger" android:layout_margin="12dp"
        android:enabled="false" app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
