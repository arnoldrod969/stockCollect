<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ProgressBar
            android:id="@+id/progress_resolution"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/group_succes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/green_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓"
                            android:textSize="18sp"
                            android:textColor="@color/green_on_container"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Article trouvé"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/green_on_container"
                            android:layout_marginStart="6dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/tv_via_table_cb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Via table CB"
                            android:textSize="10sp"
                            android:visibility="gone"
                            app:chipBackgroundColor="@color/green_secondary"
                            app:chipMinHeight="24dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_nom_article"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tv_code_produit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tv_code_barre_scanne"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Quantité"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_moins"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="−"
                            android:textSize="20sp"
                            app:cornerRadius="12dp" />

                        <TextView
                            android:id="@+id/tv_quantite"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="1.0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="@color/on_surface" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_plus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="+"
                            android:textSize="20sp"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ajouter"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Ajouter à la session"
                android:layout_marginBottom="8dp"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scanner_suivant"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Scanner le suivant"
                app:cornerRadius="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/group_echec"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/red_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✗ Code-barres inconnu"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/red_on_container"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tv_code_barre_inconnu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/red_on_container"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Non trouvé dans le catalogue ni la table de correspondance."
                        android:textSize="12sp"
                        android:textColor="@color/red_on_container" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_rescanner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Rescanner"
                app:cornerRadius="10dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
